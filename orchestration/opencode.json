{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/big-pickle",
  "default_agent": "plan",
  "permission": {
    "edit": "ask",
    "bash": "allow"
    },
  "agent": {
    "coder": {
      "description": "Writes simple, high-quality code",
      "mode": "primary",
      "model": "opencode-go/glm-5.2",
      "temperature": 0.2,
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "git *": "ask",
          "rm *": "deny"
        }
      },
      "disable": false
    },
    "architect": {
      "description": "Thinks Deeply. Plan and Designs simply",
      "mode": "primary",
      "model": "opencode-go/glm-5.2",
      "temperature": 0.3,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      },
      "disable": false
    },
    "autoresearch": {
      "description": "Writes simple, high-quality code",
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-pro",
      "temperature": 0.2,
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm *": "deny"
        }
      },
      "disable": false
    },
    "reviewer": {
      "description": "Reviews code for quality, correctness, and conventions",
      "mode": "subagent",
      "model": "opencode-go/qwen3.7-max",
      "prompt": "Look for ways to make the code more succinct and simple while retaining its functionality.",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      },
      "hidden": true,
      "disable": false
    },
    "lint": {
      "description": "Formats code and fixes import order with ruff",
      "mode": "subagent",
      "model": "opencode-go/qwen3.7-max",
      "temperature": 0.0,
      "permission": {
        "edit": "ask",
        "bash": "allow"
      },
      "hidden": true,
      "disable": false
    }
  }
}