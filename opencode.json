{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/gpt-5.2-codex",
  "agent": {
    "coder": {
      "description": "Safely refactors legacy code following REFACTORING_PLAN.md",
      "mode": "primary",
      "model": "github-copilot/gpt-5.2-codex",
      "variant": "high",
      "instructions": ".opencode/agent/coder.md",
      "temperature": 0.2,
      "tools": { "write": true, "edit": true, "bash": true }
    },
    "architect": {
      "description": "Designs systems and plans major features",
      "mode": "primary",
      "model": "github-copilot/gpt-5.2-codex",
      "variant": "balanced",
      "temperature": 0.3,
      "tools": { "write": false, "edit": false, "bash": false }
    },
    "reviewer": {
      "description": "Reviews code for quality, correctness, and conventions",
      "mode": "subagent",
      "model": "github-copilot/gpt-5.2-codex",
      "variant": "low",
      "instructions": ".opencode/agent/reviewer.md",
      "temperature": 0.1,
      "tools": { "write": false, "edit": false, "bash": false }
    },
    "debugger": {
      "description": "Investigates errors and identifies root causes",
      "mode": "subagent",
      "model": "github-copilot/gpt-5.2-codex",
      "variant": "high",
      "instructions": ".opencode/agent/debugger.md",
      "temperature": 0.0,
      "tools": { "write": false, "edit": false, "bash": true }
    },
    "validator": {
      "description": "Validates scientific/numerical code changes",
      "mode": "subagent",
      "model": "github-copilot/gpt-5.2-codex",
      "variant": "high",
      "instructions": ".opencode/agent/validator.md",
      "temperature": 0.0,
      "tools": { "write": false, "edit": false, "bash": true }
    },
    "historian": {
      "description": "Summarizes learnings and updates memory/foundations",
      "mode": "subagent",
      "model": "github-copilot/gpt-5.2-codex",
      "variant": "low",
      "instructions": ".opencode/agent/historian.md",
      "temperature": 0.0,
      "tools": { "write": true, "edit": true, "bash": false }
    },
    "lint": {
      "description": "Formats code, fixes import order, enforces naming conventions",
      "mode": "subagent",
      "model": "github-copilot/gpt-5-mini",
      "variant": "low",
      "instructions": ".opencode/agent/lint.md",
      "temperature": 0.0,
      "tools": { "write": false, "edit": true, "bash": true }
    }
  }
}